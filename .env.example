# Finance Tracker Tauri - Environment Variables
# Copy this file to .env and fill in your values

# ===========================================
# SUPABASE CONFIGURATION (Optional)
# ===========================================
# These are used for cloud sync and authentication
# You can also configure these in the app's Database Settings

# Your Supabase project URL
VITE_SUPABASE_URL=https://your-project.supabase.co

# Your Supabase anonymous key (safe to expose in frontend)
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ===========================================
# CLOUDFLARE R2 FILE UPLOAD (Optional)
# ===========================================
# For uploading images and PDFs to Cloudflare R2
# Requires deploying the r2-worker first (see r2-worker/README.md)

# URL of your deployed R2 Worker
# Example: https://finance-tracker-r2.your-subdomain.workers.dev
VITE_R2_WORKER_URL=https://finance-tracker-r2.your-subdomain.workers.dev

# ===========================================
# LOCAL STORAGE (Fallback)
# ===========================================
# If R2 is not configured, files are stored locally
# Set to true to force local storage even if R2 is configured
VITE_USE_LOCAL_STORAGE=false

# ===========================================
# APP CONFIGURATION (Optional)
# ===========================================

# App title (default: "Finance Tracker")
# VITE_APP_TITLE=Finance Tracker

# Default language (default: "en")
# VITE_DEFAULT_LANGUAGE=en

# ===========================================
# QUICK SETUP GUIDE
# ===========================================
#
# 1. LOCAL ONLY (No cloud):
#    - Don't set any variables
#    - Data stored in browser IndexedDB
#    - Files stored as base64 in localStorage
#
# 2. WITH SUPABASE (Cloud sync):
#    - Set VITE_SUPABASE_URL and VITE_SUPABASE_ANON_KEY
#    - Data synced to Supabase
#    - Can also use Supabase Storage for files
#
# 3. WITH CLOUDFLARE R2 (File uploads):
#    - Deploy r2-worker (see r2-worker/README.md)
#    - Set VITE_R2_WORKER_URL
#    - Files (images/PDFs) uploaded to R2
#
# ===========================================
# SECURITY NOTES
# ===========================================
#
# 1. In Vite, environment variables must be prefixed with VITE_
#    to be accessible in the frontend code.
#
# 2. NEVER expose sensitive keys like:
#    - R2_ACCESS_KEY_ID
#    - R2_SECRET_ACCESS_KEY
#    - Supabase service_role key
#    These are only used server-side in the r2-worker.
#
# 3. You can configure Supabase credentials directly in the app
#    through Database Settings - no need to set them here.
#
