# Finance Tracker Tauri - Environment Variables
# Copy this file to .env and fill in your values

# ===========================================
# SUPABASE CONFIGURATION (Optional)
# ===========================================
# These are used for cloud sync and authentication
# You can also configure these in the app's Database Settings

# Your Supabase project URL
VITE_SUPABASE_URL=https://your-project.supabase.co

# Your Supabase anonymous key (safe to expose in frontend)
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ===========================================
# CLOUDFLARE R2 CONFIGURATION (Optional)
# ===========================================
# Used for file storage (receipt images, attachments)
# NOTE: R2 requires a backend API - see options below

# Your Cloudflare Account ID
VITE_CLOUDFLARE_ACCOUNT_ID=your-account-id

# R2 bucket name for file uploads
VITE_R2_BUCKET_NAME=your-bucket-name

# R2 public URL (if bucket is public) or leave empty
VITE_R2_PUBLIC_URL=https://your-bucket.your-domain.com

# ===========================================
# BACKEND API URL (For R2 File Storage)
# ===========================================
# Tauri apps don't have server-side API routes like Next.js
# You have 3 options for file storage:
#
# OPTION 1: Deploy API separately (recommended for production)
#   - Deploy the Next.js API routes to Vercel/Cloudflare Workers
#   - Set VITE_API_URL to that deployment
VITE_API_URL=http://localhost:3000

# OPTION 2: Use Supabase Storage (if using Supabase)
#   - Enable Storage in your Supabase project
#   - Files stored in Supabase instead of R2
#   - No additional backend needed

# OPTION 3: Local file storage (offline only)
#   - Files stored locally on device
#   - No cloud sync for files
#   - Set VITE_USE_LOCAL_STORAGE=true
VITE_USE_LOCAL_STORAGE=false

# ===========================================
# APP CONFIGURATION (Optional)
# ===========================================

# App title (default: "Finance Tracker")
# VITE_APP_TITLE=Finance Tracker

# Default language (default: "en")
# VITE_DEFAULT_LANGUAGE=en

# ===========================================
# NOTES
# ===========================================
# 
# 1. In Vite, environment variables must be prefixed with VITE_
#    to be accessible in the frontend code.
#
# 2. For security, never expose sensitive keys like:
#    - R2_ACCESS_KEY_ID
#    - R2_SECRET_ACCESS_KEY
#    - Supabase service_role key
#    These should only be on your backend server.
#
# 3. You can configure Supabase credentials directly in the app
#    through Database Settings - no need to set them here.
#
# 4. For local-only use (no cloud sync), you don't need any
#    environment variables. The app will use IndexedDB.
#
